name: "🚀 Aura "

on:
  push:
    branches: [ main ] # Se déclenche quand l'IA finit de pusher le code

jobs:
  build:
    runs-on: macos-latest # Utilise les serveurs Mac de GitHub

    steps:
      - name: Checkout du code
        uses: actions/checkout@v4

      - name: Configuration de Xcode
        uses: maxim-lobanov/setup-xcode@v1
        with:
          xcode-version: 'latest-stable'

      - name: Installation de Fastlane
        run: bundle install || gem install fastlane

      - name: 🛠 Compilation de l'IPA
        run: |
          # Cette commande compile l'app sans avoir besoin de signature physique immédiate
          xcodebuild archive \
            -scheme "MonAppClient" \
            -archivePath ./build/MonApp.xcarchive \
            -sdk iphoneos \
            CODE_SIGNING_ALLOWED=NO

      - name: 📦 Archivage du résultat
        uses: actions/upload-artifact@v4
        with:
          name: App-Executable
          path: ./build/MonApp.xcarchive
